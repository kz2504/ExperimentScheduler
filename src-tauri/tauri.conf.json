{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Experiment Scheduler",
  "version": "0.1.0",
  "identifier": "com.frank.experimentscheduler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Experiment Scheduler",
        "label": "main",
        "width": 1680,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity"
  }
}

